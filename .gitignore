campaigns/*/
exports/*/
exports/*.png
exports/*.json
exports/audit.jsonl
!campaigns/.gitkeep
!exports/.gitkeep

# LibreOffice / acidentes (ex: alguém abriu .env no LibreOffice)
*.odt

