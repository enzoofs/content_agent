# ==========================================================================
# TimeLabs × Mendes & Vaz — Variáveis de ambiente
# Copie este arquivo para .env e preencha com as chaves reais.
# O .env NUNCA deve ser commitado (já está no .gitignore).
# ==========================================================================

# --- Geração de copy (OpenAI) ---
# Substituímos a Claude API pela OpenAI nesta fase (sem chave Anthropic).
OPENAI_API_KEY=sk-...

# --- Geração de arte (Ideogram) ---
# Ainda não temos a chave. Enquanto vazia, o pipeline usa imagens placeholder.
IDEOGRAM_API_KEY=

# Opcional: força placeholders mesmo tendo a chave Ideogram (debug/economia).
# Padrão (linha ausente ou false): usa Ideogram real quando há chave.
# USE_MOCK_IMAGES=false

# --- (Fase 2 — Buffer) ---
# BUFFER_ACCESS_TOKEN=...
# BUFFER_PROFILE_ID_INSTAGRAM=...
# BUFFER_PROFILE_ID_LINKEDIN=...

# --- (Fase 3 — Evolution API / WhatsApp — responsabilidade do Francisco) ---
# EVOLUTION_API_URL=...
# EVOLUTION_API_KEY=...
# EVOLUTION_INSTANCE=...
